# MakroGraphIntelligence — Environment Variables
# Copy this to .env and fill in your values.
# .env is gitignored — never commit actual keys.
#
# Usage:
#   export $(cat .env | xargs)   # load into shell
#   # or use python-dotenv / direnv

# ── Database passwords ────────────────────────────────────────────────────────
MAKROGRAPH_NEO4J_PASSWORD=makrograph       # Neo4j password (default: makrograph)
MAKROGRAPH_PG_PASSWORD=                    # PostgreSQL password (blank for local)

# ── LLM / AI APIs ────────────────────────────────────────────────────────────
GEMINI_API_KEY=                            # Google Gemini — https://aistudio.google.com/

# ── Macro / Data APIs ─────────────────────────────────────────────────────────
FRED_API_KEY=                              # FRED (free) — https://fred.stlouisfed.org/docs/api/fred/
EIA_API_KEY=                               # EIA (free)  — https://www.eia.gov/opendata/
CONGRESS_API_KEY=                          # Congress.gov (free) — https://api.congress.gov/sign-up/
