# IDE session files (may contain secrets in shell history)
.claude/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Virtual environment
venv/
.venv/
env/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Data (keep structure, ignore contents)
data/raw/*
data/parsed/*
data/db/*
!data/raw/.gitkeep
!data/parsed/.gitkeep
!data/db/.gitkeep

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db

# India PDFs (large binary files)
data/india/pdfs/
data/india/*.pdf

# Node dependencies
node_modules/
frontend/node_modules/

# Backup archives
backups/

# Runtime data / cache / checkpoints
data/ai_analysis_cache.json
data/pib_scan_checkpoint.txt
data/*.json
data/*.txt

# Secrets / credentials
.env
*.env
config/secrets.yaml

# Local secrets file (gitignored — copy from secrets.json.example)
config/secrets.json
